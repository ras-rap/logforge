# AI Provider (openai, ollama, or custom)
AI_PROVIDER=openai

# OpenAI Settings
# Required if AI_PROVIDER is "openai"
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4o

# Ollama Settings
# Required if AI_PROVIDER is "ollama"
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Custom OpenAI-compatible Settings
# Required if AI_PROVIDER is "custom"
CUSTOM_OPENAI_BASE_URL=https://api.yourprovider.com/v1
CUSTOM_OPENAI_API_KEY=your_api_key_here
CUSTOM_OPENAI_MODEL=your-model-name
